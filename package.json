{
  "name": "vite-plugin-unit",
  "version": "2.0.0",
  "description": "A vite plugin to enable you build websites in units.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "./dist/",
    "./LICENSE.md",
    "./README.md",
    "./package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henryhale/vite-plugin-unit.git"
  },
  "keywords": [
    "vite",
